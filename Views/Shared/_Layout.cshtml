@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Cửa hàng giày hiệu uy tín, chất lượng cao với giá cả phải chăng. Mua giày Nike, Adidas, Puma chính hãng." />
    <meta name="keywords" content="giày hiệu, giày Nike, giày Adidas, giày thể thao, cửa hàng giày" />
    <meta name="author" content="Vua Giày Hiệu" />
    <title>@ViewData["Title"] ?? "Vua Giày Hiệu - Cửa Hàng Giày Hiệu Uy Tín"</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .navbar-brand:hover { transform: scale(1.05); transition: 0.3s; }
        .cart-badge { position: relative; }
        .cart-badge .badge { position: absolute; top: -8px; right: -8px; }
        .footer-links a:hover { color: #dc3545 !important; transition: 0.3s; }
        .social-links .btn:hover { transform: translateY(-2px); transition: 0.3s; }
    </style>
</head>

<body>
    <header class="header-top bg-white shadow-sm">
        <div class="container">
            <div class="row align-items-center py-3">
                <div class="col-lg-3 col-md-4">
                    <h1 class="logo-brand m-0">
                        <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-dark fw-bold fs-4">
                            <i class="fas fa-shoe-prints text-danger me-2"></i>
                            VUA<span class="text-danger">GIAYHIEU</span>
                        </a>
                    </h1>
                </div>

                <div class="col-lg-6 col-md-4 d-none d-md-block">
                    <form asp-controller="Shoes" asp-action="Index" method="get" class="search-box d-flex">
                        <input type="text" name="search"
                               value="@(ViewContext.HttpContext.Request.Query["search"].ToString())"
                               class="form-control rounded-0" placeholder="Tìm kiếm giày..." />
                        <button type="submit" class="btn btn-danger rounded-0 px-4">
                            <i class="fas fa-search"></i>
                        </button>
                    </form>
                </div>

                <div class="col-lg-3 col-md-4 text-end">
                    <div class="d-flex align-items-center justify-content-end gap-3">
                        <div class="contact-info d-none d-lg-block">
                            <small class="text-muted d-block">
                                <i class="fas fa-phone text-danger me-1"></i>0866246437
                            </small>
                            <small class="text-muted">
                                <i class="fas fa-envelope text-danger me-1"></i>manhb282@gmail.com
                            </small>
                        </div>
                        <div class="cart-badge">
                            <a class="btn btn-outline-danger position-relative" asp-controller="Cart" asp-action="Index">
                                <i class="fas fa-shopping-cart"></i>
                                <span id="cart-count" class="badge bg-danger position-absolute top-0 start-100 translate-middle" style="display: none;">0</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <nav class="navbar navbar-expand-lg navbar-dark bg-danger">
        <div class="container">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home me-1"></i>Trang chủ
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Cuahang" ? "active" : "")"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-store me-1"></i>Cửa hàng
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="Cuahang">Tất cả sản phẩm</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" asp-controller="Shoes" asp-action="Index" asp-route-category="Giày Nam">
                                <i class="fas fa-male me-1"></i>Giày Nam</a></li>
                            <li><a class="dropdown-item" asp-controller="Shoes" asp-action="Index" asp-route-category="Giày Nữ">
                                <i class="fas fa-female me-1"></i>Giày Nữ</a></li>
                            <li><a class="dropdown-item" asp-controller="Shoes" asp-action="Index" asp-route-category="Dép">
                                <i class="fas fa-shoe-prints me-1"></i>Dép</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Gioithieu" ? "active" : "")"
                           asp-controller="Home" asp-action="Gioithieu">
                            <i class="fas fa-info-circle me-1"></i>Giới thiệu
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "tintuc" ? "active" : "")"
                           asp-controller="Home" asp-action="tintuc">
                            <i class="fas fa-newspaper me-1"></i>Tin tức
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "LienHe" ? "active" : "")"
                           asp-controller="Home" asp-action="LienHe">
                            <i class="fas fa-envelope me-1"></i>Liên hệ
                        </a>
                    </li>

                    @if (User.Identity != null && User.Identity.IsAuthenticated && Context.Session.GetString("UserRole")?.Trim() == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="AdminOrder" asp-action="Shoes">
                                <i class="fas fa-user-shield me-1"></i>TRANG QUẢN TRỊ
                            </a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        var userName = Context.Session.GetString("UserName") ?? User.Identity.Name ?? "Tài Khoản";
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-bold" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user me-1"></i>@userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                    <i class="fas fa-user-edit me-1"></i>Hồ sơ cá nhân</a></li>
                                <li><a class="dropdown-item" asp-controller="Order" asp-action="MyOrders">
                                    <i class="fas fa-list me-1"></i>Đơn hàng của tôi</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger fw-bold">
                                        <i class="fas fa-sign-out-alt me-1"></i>Đăng xuất
                                    </button>
                                </form></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">
                                <i class="fas fa-user-plus me-1"></i>Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container mt-4">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-circle-check"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-triangle-exclamation"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>

        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-5 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <h5 class="text-danger fw-bold mb-3">
                        <i class="fas fa-shoe-prints me-2"></i>VUA GIAY HIEU
                    </h5>
                    <p class="text-muted mb-3">
                        Cửa hàng chuyên cung cấp giày hiệu chính hãng và replica chất lượng cao với giá cả phải chăng.
                    </p>
                    <div class="d-flex gap-2">
                        <a href="#" class="btn btn-outline-light btn-sm"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="btn btn-outline-light btn-sm"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="btn btn-outline-light btn-sm"><i class="fab fa-tiktok"></i></a>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-3">SẢN PHẨM</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="/Shoes" class="text-muted text-decoration-none footer-links"><i class="fas fa-angle-right me-1"></i>Tất cả sản phẩm</a></li>
                        <li class="mb-2"><a href="/Shoes?category=nam" class="text-muted text-decoration-none footer-links"><i class="fas fa-angle-right me-1"></i>Giày Nam</a></li>
                        <li class="mb-2"><a href="/Shoes?category=nu" class="text-muted text-decoration-none footer-links"><i class="fas fa-angle-right me-1"></i>Giày Nữ</a></li>
                        <li class="mb-2"><a href="/Shoes?category=dep" class="text-muted text-decoration-none footer-links"><i class="fas fa-angle-right me-1"></i>Dép</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-3">HỖ TRỢ</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="/Home/Gioithieu" class="text-muted text-decoration-none footer-links"><i class="fas fa-angle-right me-1"></i>Về chúng tôi</a></li>
                        <li class="mb-2"><a href="#" class="text-muted text-decoration-none footer-links"><i class="fas fa-angle-right me-1"></i>Chính sách bán hàng</a></li>
                        <li class="mb-2"><a href="#" class="text-muted text-decoration-none footer-links"><i class="fas fa-angle-right me-1"></i>Hướng dẫn thanh toán</a></li>
                        <li class="mb-2"><a href="/Home/LienHe" class="text-muted text-decoration-none footer-links"><i class="fas fa-angle-right me-1"></i>Liên hệ</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-3">THÔNG TIN LIÊN HỆ</h6>
                    <ul class="list-unstyled text-muted">
                        <li class="mb-2"><i class="fas fa-map-marker-alt me-2"></i>123 Đường ABC, Quận XYZ, TP.HCM</li>
                        <li class="mb-2"><i class="fas fa-phone me-2"></i>0866 246 437</li>
                        <li class="mb-2"><i class="fas fa-envelope me-2"></i>manhb282@gmail.com</li>
                        <li class="mb-2"><i class="fas fa-clock me-2"></i>8:00 - 22:00 (Tất cả các ngày)</li>
                    </ul>
                </div>
            </div>

            <hr class="my-4" />

            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="text-muted mb-0">&copy; 2026 Vua Giày Hiệu. Tất cả quyền được bảo lưu.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <small class="text-muted">Phát triển bởi <a href="#" class="text-danger text-decoration-none">Vua Giày Hiệu Team</a></small>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function updateCartCount() {
            $.get('/Cart/GetCartCount', function(data) {
                if (data.count > 0) {
                    $('#cart-count').text(data.count).show();
                } else {
                    $('#cart-count').hide();
                }
            }).fail(function() {
                console.log('Không thể tải số lượng giỏ hàng');
            });
        }

        $(document).ready(function() {
            updateCartCount();
            $(document).on('cartUpdated', function() { updateCartCount(); });
        });
    </script>

    @await RenderSectionAsync("Styles", required: false)
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>