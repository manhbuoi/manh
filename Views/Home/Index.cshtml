@model List<cuahanggiay.Models.Shoe>
@{
    ViewData["Title"] = "Trang Chủ - Vua Giày Hiệu";
}

<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

<style>
    /* ========================================= */
    /* CSS FLASH SALE GIỐNG HỆT ẢNH MẪU */
    /* ========================================= */
    .fs-header-box {
        background: linear-gradient(135deg, #1e3a8a 0%, #312e81 40%, #991b1b 100%);
        border-radius: 16px 16px 0 0;
        padding: 20px 30px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    .fs-timer-box {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        color: #fff;
        font-weight: 700;
        padding: 5px 12px;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        font-size: 1.1rem;
        min-width: 45px;
        text-align: center;
    }
    .fs-body-bg {
        background-color: #ffffff;
        border-radius: 0 0 16px 16px;
        padding: 25px 20px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    /* SCROLL CONTAINER */
    .fs-scroll-container {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        gap: 20px;
        padding-bottom: 15px;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scroll-behavior: smooth;
    }
    .fs-scroll-container::-webkit-scrollbar { height: 8px; }
    .fs-scroll-container::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 10px; }
    .fs-scroll-container::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .fs-scroll-container::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    .fs-item { flex: 0 0 auto; width: 280px; scroll-snap-align: start; }

    /* ========================================= */
    /* PREMIUM PRODUCT CARDS (THẺ SẢN PHẨM CAO CẤP) */
    /* ========================================= */
    .premium-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        overflow: hidden;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    }
    .premium-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        border-color: #e2e8f0;
    }

    /* Header của thẻ (Chứa Badge & Heart) */
    .card-top-bar {
        padding: 15px 15px 0 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: absolute;
        width: 100%;
        z-index: 10;
    }
    .badge-brand {
        background-color: #374151;
        color: #fff;
        font-weight: 700;
        font-size: 0.7rem;
        padding: 4px 8px;
        border-radius: 6px;
        text-transform: uppercase;
    }
    .badge-gender {
        background-color: #f3f4f6;
        color: #4b5563;
        font-weight: 700;
        font-size: 0.7rem;
        padding: 4px 8px;
        border-radius: 6px;
        margin-left: 5px;
    }
    .heart-icon {
        color: #9ca3af;
        font-size: 1.2rem;
        cursor: pointer;
        transition: color 0.2s;
    }
    .heart-icon:hover { color: #ef4444; }

    /* Hình ảnh */
    .img-wrapper-premium {
        height: 220px;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 35px 20px 15px 20px;
        background-color: #fff;
        position: relative;
    }
    .img-fixed-premium {
        max-height: 100%;
        max-width: 100%;
        object-fit: contain;
        transition: transform 0.5s ease;
    }
    .premium-card:hover .img-fixed-premium {
        transform: scale(1.1) rotate(-2deg);
    }

    /* Nội dung */
    .card-body-premium {
        padding: 0 20px 20px 20px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }
    .shoe-name {
        font-size: 1.1rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.3;
    }
    .price-container {
        display: flex;
        align-items: baseline;
        gap: 8px;
        margin-bottom: 12px;
        flex-wrap: wrap;
    }
    .price-new {
        color: #991b1b;
        font-weight: 900;
        font-size: 1.25rem;
    }
    .price-old {
        color: #9ca3af;
        text-decoration: line-through;
        font-size: 0.9rem;
        font-weight: 600;
    }

    /* Color Swatches (Giả lập) */
    .color-swatches {
        display: flex;
        gap: 6px;
        margin-bottom: 15px;
    }
    .swatch {
        width: 18px;
        height: 18px;
        border-radius: 4px;
        border: 1px solid #e5e7eb;
        cursor: pointer;
    }
    .swatch:hover { border-color: #6b7280; }

    /* Progress bar */
    .stock-text {
        font-size: 0.75rem;
        font-weight: 800;
        color: #374151;
        margin-bottom: 5px;
        text-transform: uppercase;
    }
    .progress-bg {
        background: #f1f5f9;
        height: 6px;
        border-radius: 3px;
        width: 100%;
        margin-bottom: 15px;
        overflow: hidden;
    }
    .progress-fill {
        background: linear-gradient(90deg, #ef4444, #991b1b);
        height: 100%;
        border-radius: 3px;
    }

    /* Nút bấm */
    .btn-premium {
        background: linear-gradient(135deg, #1e3a8a 0%, #312e81 100%);
        color: white !important;
        font-weight: 800;
        border-radius: 12px;
        border: none;
        padding: 12px 0;
        width: 100%;
        font-size: 0.95rem;
        text-align: center;
        transition: all 0.3s;
        margin-top: auto;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
    }
    .btn-premium:hover {
        background: linear-gradient(135deg, #312e81 0%, #1e3a8a 100%);
        box-shadow: 0 4px 12px rgba(30, 58, 138, 0.3);
    }
</style>

@* --- 1. BANNER SECTION (GIỮ NGUYÊN) --- *@
<div class="banner-section position-relative d-flex align-items-center justify-content-center" style="min-height: 450px; 
    background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('/images/1.png') center/cover no-repeat;">
    <div class="container text-center text-white position-relative z-1">
        <h1 class="display-4 fw-bold mb-3">Giày Hiệu Chất Lượng Cao</h1>
        <p class="fs-5 mb-4">Khám phá bộ sưu tập giày hàng hiệu của chúng tôi</p>
        <a class="btn btn-outline-light btn-lg px-5 py-2 rounded-0"
           style="background-color: rgba(255, 255, 255, 0.15); border-width: 2px;" asp-controller="Home"
           asp-action="Cuahang">Mua Ngay</a>
    </div>
</div>

@* --- 2. FLASH SALE CAO CẤP (GIAO DIỆN MỚI) --- *@
<section class="flash-sale-section py-5 flash-sale-wrapper" style="background-color: #f4f6f8;">
    <div class="container">
        <div class="fs-header-box d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <i class="fas fa-bolt text-white" style="font-size: 2.2rem;"></i>
                <h2 class="fw-bold mb-0 text-white" style="font-style: italic; letter-spacing: 2px;">FLASH SALE</h2>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="text-white-50 fw-bold me-2">Kết thúc trong:</span>
                <div class="fs-timer-box" id="hours">00</div><span class="text-white fw-bold">:</span>
                <div class="fs-timer-box" id="minutes">00</div><span class="text-white fw-bold">:</span>
                <div class="fs-timer-box" id="seconds">00</div>
            </div>
        </div>

        <div class="fs-body-bg">
            <div class="fs-scroll-container" id="flash-sale-scroll">
                @if (Model != null && Model.Any())
                {
                    foreach (var shoe in Model.Take(10))
                    {
                        <div class="fs-item">
                            <div class="premium-card">
                                <div class="card-top-bar">
                                    <div>
                                        <span class="badge-brand">@(shoe.Brand?.Name ?? "Brand")</span>
                                        <span class="badge-gender">Nam/Nữ</span>
                                    </div>
                                    <i class="far fa-heart heart-icon"></i>
                                </div>

                                <a asp-controller="Shoes" asp-action="Details" asp-route-id="@shoe.Id">
                                    <div class="img-wrapper-premium">
                                        <img src="@Url.Content(string.IsNullOrEmpty(shoe.ImageUrl) ? "~/images/no-image.png" : shoe.ImageUrl)" onerror="this.onerror=null;this.src='/images/no-image.png';" alt="@shoe.Name" class="img-fixed-premium" />
                                    </div>
                                </a>

                                <div class="card-body-premium">
                                    <a asp-controller="Shoes" asp-action="Details" asp-route-id="@shoe.Id" class="text-decoration-none">
                                        <h6 class="shoe-name" title="@shoe.Name">@shoe.Name</h6>
                                    </a>
                                    
                                    <div class="price-container">
                                        <span class="price-new">@shoe.Price.ToString("#,##0") đ</span>
                                        @if (shoe.OldPrice.HasValue && shoe.OldPrice > shoe.Price) {
                                            <span class="price-old">@shoe.OldPrice.Value.ToString("#,##0") đ</span>
                                        }
                                    </div>

                                    <div class="color-swatches">
                                        <div class="swatch" style="background-color: #111827;"></div>
                                        <div class="swatch" style="background-color: #f3f4f6;"></div>
                                        <div class="swatch" style="background-color: #9ca3af;"></div>
                                    </div>

                                    @{
                                        int total = shoe.Daban + shoe.Tonkho;
                                        int currentStock = total == 0 ? 120 : total;
                                        int percent = currentStock > 0 ? (int)Math.Round((double)shoe.Daban / currentStock * 100) : 0;
                                        if (percent > 100) percent = 100;
                                    }
                                    <div class="stock-text">Sắp cháy hàng (Đã bán @shoe.Daban)</div>
                                    <div class="progress-bg"><div class="progress-fill" style="width: @percent%;"></div></div>

                                    <button class="btn-premium" onclick="@(User.Identity != null && User.Identity.IsAuthenticated ? $"addToCart({shoe.Id})" : "requireLogin()")">
                                        MUA NGAY <i class="fas fa-shopping-cart ms-1"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</section>

@* --- 3. SẢN PHẨM NỔI BẬT (GIAO DIỆN MỚI) --- *@
<section class="featured-products py-5" style="background-color: #f4f6f8;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="display-6 fw-bold text-dark mb-0" style="text-transform: uppercase;">Sản Phẩm Nổi Bật</h2>
            <a asp-controller="Home" asp-action="Cuahang" class="text-decoration-none fw-bold" style="color: #1e3a8a; font-size: 1.1rem;">Xem tất cả <i class="fas fa-arrow-right ms-1"></i></a>
        </div>
    
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var shoe in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="premium-card">
                            <div class="card-top-bar">
                                <div>
                                    <span class="badge-brand">@(shoe.Brand?.Name ?? "Brand")</span>
                                </div>
                                <i class="far fa-heart heart-icon"></i>
                            </div>

                            <a asp-controller="Shoes" asp-action="Details" asp-route-id="@shoe.Id">
                                <div class="img-wrapper-premium">
                                    <img src="@Url.Content(string.IsNullOrEmpty(shoe.ImageUrl) ? "~/images/no-image.png" : shoe.ImageUrl)" onerror="this.onerror=null;this.src='/images/no-image.png';" alt="@shoe.Name" class="img-fixed-premium" />
                                </div>
                            </a>

                            <div class="card-body-premium pt-2">
                                <a asp-controller="Shoes" asp-action="Details" asp-route-id="@shoe.Id" class="text-decoration-none">
                                    <h6 class="shoe-name" title="@shoe.Name">@shoe.Name</h6>
                                </a>
                                
                                <div class="price-container mb-3">
                                    <span class="price-new">@shoe.Price.ToString("#,##0") đ</span>
                                    @if (shoe.OldPrice.HasValue && shoe.OldPrice > shoe.Price) {
                                        <span class="price-old">@shoe.OldPrice.Value.ToString("#,##0") đ</span>
                                    }
                                </div>

                                <div class="color-swatches mb-4">
                                    <div class="swatch" style="background-color: #ef4444;"></div>
                                    <div class="swatch" style="background-color: #3b82f6;"></div>
                                    <div class="swatch" style="background-color: #fbbf24;"></div>
                                </div>

                                <button class="btn-premium" onclick="@(User.Identity != null && User.Identity.IsAuthenticated ? $"addToCart({shoe.Id})" : "requireLogin()")">
                                    MUA NGAY <i class="fas fa-shopping-cart ms-1"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-search fs-1 text-muted"></i>
                    <p class="text-muted mt-3">Không có sản phẩm nổi bật nào.</p>
                </div>
            }
        </div>
    </div>
</section>

@* --- 4. GIỚI THIỆU NGẮN (GIỮ NGUYÊN) --- *@
<section class="about-preview py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h3 class="fw-bold mb-4">Vua Giày Hiệu - Chất Lượng Là Danh Dự</h3>
                <p class="text-muted mb-4">
                    Chúng tôi cung cấp các mẫu giày hàng hiệu chính hãng từ các thương hiệu uy tín như Nike, Adidas, Puma.
                    Với cam kết chất lượng và dịch vụ tốt nhất, chúng tôi mang đến cho bạn trải nghiệm mua sắm tuyệt vời.
                </p>
                <a asp-controller="Home" asp-action="Gioithieu" class="btn btn-outline-danger">
                    <i class="fas fa-info-circle me-2"></i>Tìm Hiểu Thêm
                </a>
            </div>
            <div class="col-lg-6 mt-4 mt-lg-0">
                <img src="/images/about-preview.jpg" alt="Vua Giày Hiệu" class="img-fluid rounded shadow"
                     onerror="this.src='https://via.placeholder.com/600x400?text=Vua+Giay+Hieu'">
            </div>
        </div>
    </div>
</section>

@* --- 5. TẤT CẢ SCRIPT --- *@
<script>
    // Xử lý đổi màu trái tim
    document.querySelectorAll('.heart-icon').forEach(icon => {
        icon.addEventListener('click', function(e) {
            e.preventDefault();
            this.classList.toggle('far');
            this.classList.toggle('fas');
            this.classList.toggle('text-danger');
        });
    });

    // Cập nhật giá
    var priceRange = document.getElementById('priceRange');
    if (priceRange) {
        priceRange.addEventListener('input', function () {
            document.getElementById('priceValue').textContent = parseInt(this.value).toLocaleString('vi-VN');
        });
    }

    // Đồng hồ đếm ngược
    const countDownDate = new Date().getTime() + (5 * 60 * 60 * 1000);
    const timerInterval = setInterval(function () {
        const now = new Date().getTime();
        const distance = countDownDate - now;

        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        document.getElementById("hours").innerHTML = hours < 10 ? "0" + hours : hours;
        document.getElementById("minutes").innerHTML = minutes < 10 ? "0" + minutes : minutes;
        document.getElementById("seconds").innerHTML = seconds < 10 ? "0" + seconds : seconds;

        if (distance < 0) {
            clearInterval(timerInterval);
            document.querySelector('.flash-sale-wrapper').style.display = 'none';
        }
    }, 1000);

    // Auto scroll Flash Sale
    const scrollContainer = document.getElementById('flash-sale-scroll');
    let autoScrollInterval;
    let scrollDirection = 1;

    const startAutoScroll = () => {
        autoScrollInterval = setInterval(() => {
            if (scrollContainer) {
                const itemWidth = scrollContainer.querySelector('.fs-item').offsetWidth + 20;
                if (scrollDirection === 1 && scrollContainer.scrollLeft + scrollContainer.clientWidth >= scrollContainer.scrollWidth - 10) {
                    scrollDirection = -1;
                } else if (scrollDirection === -1 && scrollContainer.scrollLeft <= 10) {
                    scrollDirection = 1;
                }
                scrollContainer.scrollBy({ left: itemWidth * scrollDirection, behavior: 'smooth' });
            }
        }, 3000);
    };

    if (scrollContainer) {
        startAutoScroll();
        scrollContainer.addEventListener('mouseenter', () => clearInterval(autoScrollInterval));
        scrollContainer.addEventListener('touchstart', () => clearInterval(autoScrollInterval));
        scrollContainer.addEventListener('mouseleave', startAutoScroll);
        scrollContainer.addEventListener('touchend', startAutoScroll);
    }

    function requireLogin() {
        alert("Vui lòng đăng nhập hoặc đăng ký để tiếp tục mua hàng!");
        window.location.href = "/Account/Login?returnUrl=" + encodeURIComponent(window.location.pathname);
    }
</script>