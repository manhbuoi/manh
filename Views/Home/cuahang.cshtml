@model IEnumerable<cuahanggiay.Models.Shoe>
@{
    ViewData["Title"] = "Cửa Hàng - Vua Giày Hiệu";
    Layout = "_Layout";
}

<div class="breadcrumb-section bg-light py-2">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"
                                                   class="text-decoration-none text-dark">Trang chủ</a></li>
                    <li class="breadcrumb-item active text-danger">Cửa hàng</li>
                </ol>
            </nav>
        </div>
    </div>

    <section class="products-section py-5 bg-light">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="display-5 fw-bold text-dark">Sản Phẩm Nổi Bật</h2>
                <p class="text-muted fs-5">Những mẫu giày hot nhất đang được khách hàng yêu thích</p>
            </div>

            @if (Model != null && Model.Any())
            {
                var groupedShoes = Model.GroupBy(s => s.Category?.Name ?? "Khác");
                foreach (var group in groupedShoes)
                {
                    <div class="category-section mb-5">
                        <h3 class="text-center mb-4 text-primary">@group.Key</h3>
                        <div class="row g-4">
                            @foreach (var shoe in group)
                            {
                                <div class="col-lg-4 col-md-6">
                                    <div class="card h-100 shadow-sm border-0 product-card">
                                        <div class="position-relative overflow-hidden">
                                            <img src="@Url.Content(string.IsNullOrEmpty(shoe.ImageUrl) ? "~/images/default-shoe.jpg" : shoe.ImageUrl)"
                                                 alt="@shoe.Name" class="card-img-top product-image"
                                                 onerror="this.src='https://via.placeholder.com/300x250?text=@shoe.Name.Replace(" ", "+")'">
                                        
                                            @if (shoe.OldPrice.HasValue && shoe.OldPrice > shoe.Price)
                                            {
                                                <span class="badge bg-danger position-absolute top-0 start-0 m-2">
                                                    -@Math.Round((1 - (double)shoe.Price / (double)shoe.OldPrice.Value) * 100)%
                                                </span>
                                            }
                                            @if (shoe.IsFeatured)
                                            {
                                                <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">
                                                    <i class="fas fa-star me-1"></i>Nổi bật
                                                </span>
                                            }
                                        </div>

                                        <div class="card-body p-4">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <span class="badge bg-light text-muted">@(shoe.Brand?.Name ?? "N/A")</span>
                                                <span class="badge bg-light text-muted">@(shoe.Category?.Name ?? "N/A")</span>
                                            </div>

                                            <h5 class="card-title fw-bold mb-2">@shoe.Name</h5>

                                            <p class="text-muted small mb-3">@shoe.Description</p>

                                            <div class="rating mb-3">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <i class="fas fa-star @(i <= shoe.Rating ? "text-warning" : "text-muted")"></i>
                                                }
                                                <small class="text-muted ms-1">(@shoe.Daban lượt bán)</small>
                                            </div>

                                            <div class="price-section mb-3">
                                                <span class="text-danger fw-bold fs-4">@shoe.Price.ToString("#,##0") đ</span>
                                                @if (shoe.OldPrice.HasValue)
                                                {
                                                    <span
                                                        class="text-muted text-decoration-line-through ms-2">@shoe.OldPrice.Value.ToString("#,##0")
                                                        đ</span>
                                                    }
                                                </div>

                                                <div class="stock-status mb-3">
                                                    @if (shoe.Tonkho > 10)
                                                    {
                                                        <small class="text-success"><i class="fas fa-check-circle me-1"></i>Còn hàng
                                                            (@shoe.Tonkho)</small>
                                                        }
                                            else if (shoe.Tonkho > 0)
                                                        {
                                                            <small class="text-warning"><i class="fas fa-exclamation-triangle me-1"></i>Sắp hết hàng
                                                                (@shoe.Tonkho)</small>
                                                            }
                                            else
                                                            {
                                                                <small class="text-danger"><i class="fas fa-times-circle me-1"></i>Hết hàng</small>
                                                            }
                                                        </div>
                                                    </div>

                                                    <div class="card-footer bg-white border-0 p-4 pt-0">
                                                        <div class="d-grid gap-2">
                                                            <a asp-controller="Shoes" asp-action="Details" asp-route-id="@shoe.Id"
                                                                   class="btn btn-outline-primary">
                                                                <i class="fas fa-eye me-2"></i>Xem Chi Tiết
                                                            </a>
                                                            @if (shoe.Tonkho > 0)
                                                            {
                                                                <button class="btn btn-danger" onclick="addToCart(@shoe.Id)">
                                                                    <i class="fas fa-cart-plus me-2"></i>Thêm Vào Giỏ
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <button class="btn btn-secondary" disabled>
                                                                    <i class="fas fa-cart-plus me-2"></i>Hết Hàng
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="text-center mt-5">
                                <a asp-controller="Shoes" asp-action="Index" class="btn btn-danger btn-lg px-5">
                                    <i class="fas fa-th-large me-2"></i>Xem Tất Cả Sản Phẩm
                                </a>
                            </div>
                        }
        else
                        {
                            <div class="text-center py-5">
                                <div class="alert alert-light shadow-sm border">
                                    <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                                    <h4 class="text-muted">Không có sản phẩm nào</h4>
                                    <p class="text-muted mb-0">Hiện tại cửa hàng chưa có sản phẩm. Vui lòng quay lại sau.</p>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <section class="about-preview py-5 bg-white">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-6">
                                <h3 class="fw-bold mb-4">Vua Giày Hiệu - Chất Lượng Là Danh Dự</h3>
                                <p class="text-muted mb-4">
                                    Chúng tôi cung cấp các mẫu giày hàng hiệu chính hãng từ các thương hiệu uy tín như Nike, Adidas,
                                    Puma.
                                    Với cam kết chất lượng và dịch vụ tốt nhất, chúng tôi mang đến cho bạn trải nghiệm mua sắm tuyệt
                                    vời.
                                </p>
                                <a asp-controller="Home" asp-action="Gioithieu" class="btn btn-outline-danger">
                                    <i class="fas fa-info-circle me-2"></i>Tìm Hiểu Thêm
                                </a>
                            </div>
                            <div class="col-lg-6">
                                <img src="~/images/about-preview.jpg" alt="Vua Giày Hiệu" class="img-fluid rounded shadow"
                                     onerror="this.src='https://via.placeholder.com/600x400?text=Vua+Giay+Hieu'">
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="why-choose-us py-5 bg-light">
                        <div class="container">
                            <div class="text-center mb-5">
                                <h2 class="display-5 fw-bold text-dark">Tại Sao Chọn Chúng Tôi?</h2>
                                <p class="text-muted fs-5">Cam kết mang đến trải nghiệm mua sắm tốt nhất cho bạn</p>
                            </div>
                            <div class="row g-4">
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <i class="fas fa-shield-alt fa-3x text-primary mb-3"></i>
                                        <h5 class="fw-bold">Chính Hãng 100%</h5>
                                        <p class="text-muted">Tất cả sản phẩm đều là hàng chính hãng từ nhà sản xuất</p>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <i class="fas fa-truck fa-3x text-success mb-3"></i>
                                        <h5 class="fw-bold">Giao Hàng Miễn Phí</h5>
                                        <p class="text-muted">Miễn phí giao hàng cho đơn hàng trên 500.000đ</p>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <i class="fas fa-undo fa-3x text-warning mb-3"></i>
                                        <h5 class="fw-bold">Đổi Trả Dễ Dàng</h5>
                                        <p class="text-muted">Chính sách đổi trả trong 30 ngày với sản phẩm còn mới</p>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <i class="fas fa-headset fa-3x text-info mb-3"></i>
                                        <h5 class="fw-bold">Hỗ Trợ 24/7</h5>
                                        <p class="text-muted">Đội ngũ chăm sóc khách hàng luôn sẵn sàng hỗ trợ bạn</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="stats-section py-5 bg-white">
                        <div class="container">
                            <div class="row text-center g-4">
                                <div class="col-md-3">
                                    <div class="stat-item">
                                        <i class="fas fa-shoe-prints fa-3x text-primary mb-3"></i>
                                        <h3 class="fw-bold text-primary">@(Model?.Count() ?? 0)</h3>
                                        <p class="text-muted mb-0">Sản Phẩm</p>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="stat-item">
                                        <i class="fas fa-users fa-3x text-success mb-3"></i>
                                        <h3 class="fw-bold text-success">@(Model?.Sum(s => s.Daban) ?? 0)</h3>
                                        <p class="text-muted mb-0">Khách Hàng Hài Lòng</p>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="stat-item">
                                        <i class="fas fa-star fa-3x text-warning mb-3"></i>
                                        <h3 class="fw-bold text-warning">@((Model?.Any() == true ? Model.Average(s => s.Rating) :
                                                                    0).ToString("0.0"))</h3>
                                            <p class="text-muted mb-0">Đánh Giá Trung Bình</p>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="stat-item">
                                            <i class="fas fa-truck fa-3x text-info mb-3"></i>
                                            <h3 class="fw-bold text-info">24/7</h3>
                                            <p class="text-muted mb-0">Hỗ Trợ Khách Hàng</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <script>
                            // Check if user is authenticated based on session
                            var isAuthenticated = @Json.Serialize(Context.Session.GetString("UserName") != null);
                        </script>

                        @section Styles {
                            <style>
                                .hero-section {
                                    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                                    min-height: 400px;
                                    display: flex;
                                    align-items: center;
                                }

                                .product-card {
                                    transition: all 0.3s ease;
                                    border-radius: 15px;
                                    overflow: hidden;
                                }

                                .product-card:hover {
                                    transform: translateY(-10px);
                                    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
                                }

                                .product-image {
                                    height: 250px;
                                    object-fit: cover;
                                    transition: transform 0.3s ease;
                                }

                                .product-card:hover .product-image {
                                    transform: scale(1.05);
                                }

                                .rating .fa-star {
                                    font-size: 0.9rem;
                                }

                                .stat-item {
                                    padding: 2rem;
                                    border-radius: 10px;
                                    background: #f8f9fa;
                                    transition: transform 0.3s ease;
                                }

                                .stat-item:hover {
                                    transform: translateY(-5px);
                                }

                                .breadcrumb-section {
                                    border-bottom: 1px solid #e9ecef;
                                }

                                .btn {
                                    border-radius: 25px;
                                    font-weight: 600;
                                    text-transform: uppercase;
                                    letter-spacing: 0.5px;
                                }
                            </style>
                        }

                        @section Scripts {
                            <script>
                                function addToCart(id) {
                                    // Hiển thị thông báo thành công
                                    const toast = document.createElement('div');
                                    toast.className = 'alert alert-success alert-dismissible fade show position-fixed';
                                    toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
                                    toast.innerHTML = `
                                            <i class="fas fa-check-circle me-2"></i>Sản phẩm đã được thêm vào giỏ hàng!
                                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                        `;
                                    document.body.appendChild(toast);

                                    // Tự động ẩn sau 3 giây
                                    setTimeout(() => {
                                        toast.remove();
                                    }, 3000);

                                    // Gửi request thêm vào giỏ
                                    fetch('/Cart/AddToCartAjax', {
                                        method: 'POST',
                                        headers: {
                                            'Content-Type': 'application/json',
                                        },
                                        body: JSON.stringify({ shoeId: id, quantity: 1 })
                                    })
                                        .then(response => response.json())
                                        .then(data => {
                                            if (data.success) {
                                                const toast = document.createElement('div');
                                                toast.className = 'alert alert-success alert-dismissible fade show position-fixed';
                                                toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
                                                toast.innerHTML = `
                                                    <i class="fas fa-check-circle me-2"></i>${data.message}
                                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                                `;
                                                document.body.appendChild(toast);

                                                setTimeout(() => {
                                                    toast.remove();
                                                }, 3000);
                                            } else {
                                                alert(data.message);
                                            }
                                        })
                                        .catch(error => {
                                            console.log('Error:', error);
                                            const toast = document.createElement('div');
                                            toast.className = 'alert alert-info alert-dismissible fade show position-fixed';
                                            toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
                                            toast.innerHTML = `
                                                <i class="fas fa-info-circle me-2"></i>Sản phẩm đã được thêm vào giỏ hàng (demo mode)
                                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                            `;
                                            document.body.appendChild(toast);
                                            setTimeout(() => {
                                                toast.remove();
                                            }, 3000);
                                        });
                                }
                            </script>
                        }