                <div class="branch-card">
                    <div class="branch-icon">
                        <i class="fas fa-store"></i>
                    </div>
                    <h5>Hà Nội - Chi Nhánh 1</h5>
                    <p>Số 12A Ngõ 193 Trung Kính, Phường Yên Hòa, Quận Cầu Giấy</p>
                    <p class="branch-phone"><i class="fas fa-phone"></i> 0987 XXX XXX</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="branch-card">
                    <div class="branch-icon">
                        <i class="fas fa-store"></i>
                    </div>
                    <h5>Hà Nội - Chi Nhánh 2</h5>
                    <p>P.605, Số 6 Đội Nhân, Vĩnh Phú, Ba Đình</p>
                    <p class="branch-phone"><i class="fas fa-phone"></i> 0987 XXX XXX</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="branch-card">
                    <div class="branch-icon">
                        <i class="fas fa-store"></i>
                    </div>
                    <h5>Hà Nội - Chi Nhánh 3</h5>
                    <p>Tầng 405, Chung cư C7, Ngõ 44 Nguyễn Cơ Thạch, Cầu Diễn</p>
                    <p class="branch-phone"><i class="fas fa-phone"></i> 0987 XXX XXX</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="branch-card">
                    <div class="branch-icon">
                        <i class="fas fa-store"></i>
                    </div>
                    <h5>Hà Nội - Chi Nhánh 4</h5>
                    <p>P.502, Tòa S4 Goldmark City, 136 Hồ Tùng Mậu, Cầu Diễn</p>
                    <p class="branch-phone"><i class="fas fa-phone"></i> 0987 XXX XXX</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="branch-card">
                    <div class="branch-icon">
                        <i class="fas fa-store"></i>
                    </div>
                    <h5>Hà Nội - Chi Nhánh 5</h5>
                    <p>Số 89 Đồng Cổ, Phường Bưởi, Tây Hồ</p>
                    <p class="branch-phone"><i class="fas fa-phone"></i> 0987 XXX XXX</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="branch-card">
                    <div class="branch-icon">
                        <i class="fas fa-store"></i>
                    </div>
                    <h5>TP.HCM</h5>
                    <p>103 Bà Hạt, Phường 9, Quận 10</p>
                    <p class="branch-phone"><i class="fas fa-phone"></i> 0987 XXX XXX</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}