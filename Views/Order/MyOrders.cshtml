@model IEnumerable<cuahanggiay.Models.Order>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container mt-4 mb-5">
    <h2 class="mb-4 text-danger fw-bold"><i class="fas fa-history me-2"></i>Lịch sử đơn hàng của bạn</h2>

    @if (Model != null && Model.Any())
    {
        foreach (var order in Model)
        {
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header text-white d-flex justify-content-between align-items-center"
                     style="background-color: #2c3e50;">
                    <div>
                        <span class="fs-5 fw-bold">Mã Đơn: #@order.OrderCode</span> <br />
                        <small class="text-light"><i class="far fa-calendar-alt me-1"></i> Ngày đặt:
                            @order.OrderDate.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <div>
                            @if (order.Status == "Chờ xử lý")
                            {
                                <span class="badge bg-warning text-dark fs-6 px-3 py-2"><i class="fas fa-clock me-1"></i>Chờ xử
                                    lý</span>
                                }
                        else if (order.Status == "Đang giao" || order.Status == "Đã duyệt")
                                {
                                    <span class="badge bg-info text-dark fs-6 px-3 py-2"><i class="fas fa-truck me-1"></i>Đang giao</span>
                                }
                                else if (order.Status == "Hoàn thành")
                                {
                                    <span class="badge bg-success fs-6 px-3 py-2"><i class="fas fa-check-circle me-1"></i>Hoàn thành</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6 px-3 py-2"><i class="fas fa-times-circle me-1"></i>Đã hủy</span>
                                }
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-borderless mb-0 align-middle">
                                    <thead class="table-light border-bottom">
                                        <tr>
                                            <th class="ps-4">Sản phẩm</th>
                                            <th class="text-center">Số lượng</th>
                                            <th class="text-end pe-4">Đơn giá</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (order.OrderItems != null)
                                        {
                                            foreach (var item in order.OrderItems)
                                            {
                                                <tr class="border-bottom">
                                                    <td class="ps-4">
                                                        <div class="d-flex align-items-center">
                                                            <img src="@(item.Shoe?.ImageUrl ?? "/images/default.jpg")"
                                                                 style="width: 60px; height: 60px; object-fit: cover;"
                                                                 class="rounded border shadow-sm me-3" />
                                                            <span class="fw-bold">@(item.Shoe?.Name ?? "Sản phẩm không xác định")</span>
                                                        </div>
                                                    </td>
                                                    <td class="text-center fw-bold">@item.Quantity</td>
                                                    <td class="text-end text-danger fw-bold pe-4">
                                                        @(item.Shoe?.Price.ToString("N0") ?? "0") ₫
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="card-footer bg-light text-end py-3 pe-4">
                            @{
                                // Tính tổng tiền dựa trên giá của Shoe (vì lúc trước mình đã ẩn cột Price ở bảng OrderItem)
                                decimal total = order.OrderItems?.Sum(i => (i.Shoe?.Price ?? 0) * i.Quantity) ?? 0;
                            }
                            <span class="text-muted me-3 fs-5">Tổng tiền thanh toán:</span>
                            <span class="text-danger fw-bold fs-4">@total.ToString("N0") ₫</span>
                        </div>
                    </div>
                }
            }
    else
            {
                <div class="text-center py-5 bg-light rounded shadow-sm border">
                    <i class="fas fa-box-open text-secondary mb-3" style="font-size: 5rem;"></i>
                    <h4 class="text-muted mb-4">Bạn chưa có đơn hàng nào!</h4>
                    <a asp-controller="Shoes" asp-action="Index" class="btn btn-danger px-4 py-2 fw-bold text-uppercase">Mua sắm
                        ngay</a>
                    </div>
                }
            </div>