@model cuahanggiay.Models.Shoe

@{
    ViewData["Title"] = Model.Name;
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0 m-0">
            <li class="breadcrumb-item"><a href="/" class="text-success text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Shoes" class="text-success text-decoration-none">Dép Hiệu</a></li>
            <li class="breadcrumb-item"><a href="/Shoes?category=@Model.Category?.Name.ToLower()" class="text-success text-decoration-none">@Model.Category?.Name</a></li>
            <li class="breadcrumb-item active text-dark" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row bg-white p-4 shadow-sm position-relative">
        <div class="sale-badge">@(Model.OldPrice.HasValue && Model.OldPrice > Model.Price ? $"{Math.Round((1 - Model.Price / Model.OldPrice.Value) * 100)}%" : "")</div>

        <div class="col-md-6 mb-4 mb-md-0">
            <div class="product-gallery position-relative text-center border">
                <button class="btn btn-dark btn-sm position-absolute top-0 end-0 m-2 rounded-circle zoom-btn">
                    <i class="bi bi-search"></i>
                </button>
            
                <img src="~/images/@Model.ImageUrl" alt="@Model.Name"
                     class="img-fluid w-100" />
            
                <button class="gallery-nav prev-btn position-absolute top-50 start-0 translate-middle-y border-0"><i
                    class="bi bi-chevron-left"></i></button>
                    <button class="gallery-nav next-btn position-absolute top-50 end-0 translate-middle-y border-0"><i
                        class="bi bi-chevron-right"></i></button>
                    </div>
                </div>

                <div class="col-md-6 ps-md-4">
                    <h1 class="product-title h4 fw-bold mb-3">@Model.Name</h1>
        
                        <div class="product-price mb-3">
                            @if (Model.OldPrice.HasValue && Model.OldPrice > Model.Price)
                            {
                                <span class="current-price text-success fs-3 fw-bold me-3">@Model.Price.ToString("N0") ₫</span>
                                <span class="old-price text-dark text-decoration-line-through fs-5 fw-bold">@Model.OldPrice.Value.ToString("N0") ₫</span>
                            }
                            else
                            {
                                <span class="current-price text-success fs-3 fw-bold me-3">@Model.Price.ToString("N0") ₫</span>
                            }
                        </div>

                            <div class="product-sizes mb-4">
                                <p class="fw-bold mb-2">Size <span class="text-danger">*</span></p>
                                <div class="d-flex flex-wrap gap-2">
                                    <label class="size-box">
                                        <input type="radio" name="size" value="38" required />
                                        <span>38</span>
                                    </label>
                                    <label class="size-box">
                                        <input type="radio" name="size" value="39" required />
                                        <span>39</span>
                                    </label>
                                    <label class="size-box">
                                        <input type="radio" name="size" value="40" required />
                                        <span>40</span>
                                    </label>
                                    <label class="size-box">
                                        <input type="radio" name="size" value="41" required />
                                        <span>41</span>
                                    </label>
                                    <label class="size-box">
                                        <input type="radio" name="size" value="42" required />
                                        <span>42</span>
                                    </label>
                                    <label class="size-box">
                                        <input type="radio" name="size" value="43" required />
                                        <span>43</span>
                                    </label>
                                    <label class="size-box">
                                        <input type="radio" name="size" value="44" required />
                                        <span>44</span>
                                    </label>
                                </div>
                                <div id="sizeError" class="text-danger mt-1" style="display: none;">Vui lòng chọn size.</div>
                            </div>

                            <form id="cartForm" asp-controller="Cart" asp-action="AddToCart" method="post"
                                  class="product-actions d-flex align-items-center gap-3 mb-4">
                                <input type="hidden" name="productId" value="@Model.Id" />
                                <input type="hidden" name="productName" value="@Model.Name" />
                                <input type="hidden" name="price" value="@Model.Price" />
                                <input type="hidden" name="imageUrl" value="@Model.ImageUrl" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <div class="d-flex align-items-center gap-2">
                                    <label for="quantity" class="fw-bold mb-0">Số lượng:</label>
                                    <input type="number" id="quantity" name="quantity" value="1" min="1" class="form-control text-center quantity-input"
                                           style="width: 70px;" required />
                                </div>
                
                                <button type="submit" id="buyNowBtn" name="action" value="buy_now"
                                        class="btn btn-success fw-bold px-4 py-2 rounded-0" disabled>MUA NGAY</button>
                                <button type="submit" id="addCartBtn" name="action" value="add_cart"
                                        class="btn btn-secondary fw-bold px-3 py-2 rounded-0 text-white"
                                        style="background-color: #6c757d; border-color: #6c757d;" disabled>
                                    Thêm vào giỏ hàng <i class="bi bi-bag ms-1"></i>
                                </button>
                            </form>

                            <div class="product-specs border p-1 mt-4">
                                <table class="table table-bordered mb-0">
                                    <tbody>
                                        <tr>
                                            <td class="w-25">Tên sản phẩm:</td>
                                            <td colspan="2">Dép Hermes Izmir Sandal Quai Chữ H Màu Xanh Lót Nâu Đế Trắng Like Auth</td>
                                        </tr>
                                        <tr>
                                            <td class="align-middle" rowspan="2">Loại hàng</td>
                                            <td class="text-center fw-bold">Bản Siêu Cấp</td>
                                            <td class="text-center fw-bold">Bản Like Auth</td>
                                        </tr>
                                        <tr>
                                            <td class="text-center text-danger fw-bold">1.490.000 VNĐ</td>
                                            <td class="text-center text-danger fw-bold">2.990.000 VNĐ</td>
                                        </tr>
                                        <tr>
                                            <td>Xuất xứ</td>
                                            <td colspan="2" class="fw-bold">Hồng Kông</td>
                                        </tr>
                                        <tr>
                                            <td>Bộ sưu tập</td>
                                            <td colspan="2" class="fw-bold">Dép Hermes</td>
                                        </tr>
                                        <tr>
                                            <td>Chất liệu</td>
                                            <td colspan="2" class="fw-bold">Da Cao Cấp</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Update cart count after page load (in case item was added)
            if (typeof updateCartCount === 'function') {
                updateCartCount();
            }

            // Handle quantity change
            $('#quantity').change(function() {
                validateForm();
            });

            // Handle size change
            $('input[name="size"]').change(function() {
                $('#sizeError').hide();
                validateForm();
            });

            // Validate form and enable/disable buttons
            function validateForm() {
                var sizeSelected = $('input[name="size"]:checked').length > 0;
                var quantity = parseInt($('#quantity').val()) || 0;
                var isValid = sizeSelected && quantity > 0;

                $('#buyNowBtn, #addCartBtn').prop('disabled', !isValid);

                if (!sizeSelected) {
                    $('#sizeError').show();
                } else {
                    $('#sizeError').hide();
                }
            }

            // Initial validation
            validateForm();
        });
    </script>
}
