@model List<cuahanggiay.Models.User>
@{
    ViewData["Title"] = "Quản lý Tài khoản & Phân quyền";
    Layout = "_Layout";
}

<div class="bg-light pb-5">
    <!-- Header Page -->
    <div class="bg-white shadow-sm pt-4 pb-3 mb-4">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1"><i class="fas fa-users-cog text-primary me-2"></i>Quản Lý Phân Quyền Tổ Chức</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 small">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang Chủ</a></li>
                        <li class="breadcrumb-item"><a asp-controller="AdminOrder" asp-action="Dashboard" class="text-decoration-none">Admin</a></li>
                        <li class="breadcrumb-item active text-danger" aria-current="page">Quản Lý Users</li>
                    </ol>
                </nav>
            </div>
            <div>
                <span class="badge bg-custom-dark p-2 fs-6">
                    <i class="fas fa-shield-alt text-warning me-1"></i> Admin Privileges Active
                </span>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-list-ul text-danger me-2"></i>Danh sách nhân sự và khách hàng hệ thống</h5>
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted">
                        <tr>
                            <th scope="col" class="py-3 px-4">#ID</th>
                            <th scope="col" class="py-3">Họ Tên / Biệt Danh</th>
                            <th scope="col" class="py-3">Email (Tên đăng nhập)</th>
                            <th scope="col" class="py-3 text-center">Vai Trò Hiện Tại</th>
                            <th scope="col" class="py-3 px-4 text-center">Phân Quyền Lại</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var user in Model.OrderBy(u => u.Role == "Admin" ? 0 : u.Role == "StoreOwner" ? 1 : u.Role == "Shipper" ? 2 : 3))
                        {
                            <tr>
                                <td class="px-4 fw-bold text-muted">#@user.Id</td>
                                <td class="fw-medium text-dark">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle bg-light text-primary fw-bold d-flex align-items-center justify-content-center border me-3" style="width: 35px; height: 35px; border-radius: 50%;">
                                            @(user.FullName != null && user.FullName.Length > 0 ? user.FullName.Substring(0, 1).ToUpper() : "?")
                                        </div>
                                        @user.FullName
                                    </div>
                                </td>
                                <td>@user.Email</td>
                                <td class="text-center">
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="fas fa-crown me-1"></i>Admin Tối Cao</span>
                                    }
                                    else if (user.Role == "StoreOwner")
                                    {
                                        <span class="badge bg-primary px-3 py-2 rounded-pill"><i class="fas fa-store me-1"></i>Chủ Cửa Hàng</span>
                                    }
                                    else if (user.Role == "Shipper")
                                    {
                                        <span class="badge bg-info text-dark px-3 py-2 rounded-pill"><i class="fas fa-motorcycle me-1"></i>Vận Chuyển</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-3 py-2 rounded-pill"><i class="fas fa-user-tag me-1"></i>Khách Hàng</span>
                                    }
                                </td>
                                <td class="px-4 text-center">
                                    <!-- Form cấp quyền chuyên nghiệp -->
                                    <form method="post" asp-controller="AdminOrder" asp-action="ChangeRole" class="d-inline-flex gap-2 w-100 justify-content-center">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <select name="role" class="form-select form-select-sm bg-light shadow-none w-auto" style="min-width: 140px; cursor: pointer;">
                                            <option value="Admin" selected="@(user.Role == "Admin")">Admin (Toàn quyền)</option>
                                            <option value="StoreOwner" selected="@(user.Role == "StoreOwner")">Store Owner (Quản lý hàng)</option>
                                            <option value="Shipper" selected="@(user.Role == "Shipper")">Shipper (Giao hàng)</option>
                                            <option value="Customer" selected="@(string.IsNullOrEmpty(user.Role) || user.Role == "Customer")">Customer (Người mua)</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-dark fw-bold px-3 shadow-sm dynamic-btn">
                                            Lưu <i class="fas fa-save ms-1"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-users fa-3x text-muted mb-3 opacity-50"></i>
                    <p class="text-muted fw-medium">Chưa có người dùng nào trong hệ thống.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-custom-dark { background-color: #1e293b; }
        .dynamic-btn { transition: all 0.2s; }
        .dynamic-btn:hover { background-color: #dc3545; border-color: #dc3545; transform: translateY(-1px); }
        .table > :not(caption) > * > * { padding: 1rem 0.5rem; }
        tbody tr { transition: background-color 0.2s; }
        tbody tr:hover { background-color: #f8fafc; }
    </style>
}