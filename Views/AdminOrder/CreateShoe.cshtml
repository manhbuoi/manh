@model cuahanggiay.Models.Shoe
@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="text-primary fw-bold mb-4">Thêm Sản Phẩm Mới</h2>

<div class="card shadow col-md-8">
    <div class="card-body">
        <form asp-action="CreateShoe" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">Tên giày <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                    <input asp-for="Price" type="number" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Số lượng tồn kho <span class="text-danger">*</span></label>
                    <input asp-for="Tonkho" type="number" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" required>
                    <option value="">-- Chọn danh mục --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Link Hình ảnh (URL)</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả sản phẩm</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4">Lưu Sản Phẩm</button>
                <a asp-action="Shoes" class="btn btn-secondary px-4">Hủy & Quay lại</a>
            </div>
        </form>
    </div>
</div>