@model cuahanggiay.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Báo cáo Thống Kê";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-3">
    <h2 class="mb-4 fw-bold"><i class="fas fa-chart-pie text-danger me-2"></i> BẢNG ĐIỀU KHIỂN & THỐNG KÊ</h2>

    <!-- Thẻ tóm tắt -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-sm-6">
            <div class="card shadow-sm border-0 bg-white h-100 pb-2 border-bottom border-danger border-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col">
                            <h6 class="text-uppercase text-muted fw-bold mb-2">DOANH THU TỔNG</h6>
                            <span class="h4 font-weight-bold mb-0 text-dark">@Model.TotalRevenue.ToString("N0") ₫</span>
                        </div>
                        <div class="col-auto">
                            <div class="icon icon-shape bg-danger text-white rounded-circle shadow d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <i class="fas fa-dollar-sign fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-sm-6">
            <div class="card shadow-sm border-0 bg-white h-100 pb-2 border-bottom border-primary border-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col">
                            <h6 class="text-uppercase text-muted fw-bold mb-2">TỔNG ĐƠN HÀNG</h6>
                            <span class="h4 font-weight-bold mb-0 text-dark">@Model.TotalOrders <small>đơn</small></span>
                        </div>
                        <div class="col-auto">
                            <div class="icon icon-shape bg-primary text-white rounded-circle shadow d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <i class="fas fa-shopping-cart fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card shadow-sm border-0 bg-white h-100 pb-2 border-bottom border-success border-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col">
                            <h6 class="text-uppercase text-muted fw-bold mb-2">KHÁCH HÀNG</h6>
                            <span class="h4 font-weight-bold mb-0 text-dark">@Model.TotalCustomers <small>người</small></span>
                        </div>
                        <div class="col-auto">
                            <div class="icon icon-shape bg-success text-white rounded-circle shadow d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <i class="fas fa-users fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card shadow-sm border-0 bg-white h-100 pb-2 border-bottom border-warning border-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col">
                            <h6 class="text-uppercase text-muted fw-bold mb-2">SỐ MẪU GIÀY</h6>
                            <span class="h4 font-weight-bold mb-0 text-dark">@Model.TotalProducts <small>sản phẩm</small></span>
                        </div>
                        <div class="col-auto">
                            <div class="icon icon-shape bg-warning text-white rounded-circle shadow d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <i class="fas fa-shoe-prints fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Biểu đồ -->
        <div class="col-xl-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-chart-bar text-primary me-2"></i> Doanh thu 7 ngày gần nhất</h5>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" style="min-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <!-- Đơn hàng gần đây -->
        <div class="col-xl-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-clock text-danger me-2"></i> 5 Đơn hàng Mới nhất</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Khách hàng</th>
                                    <th>Giá trị</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="fas fa-user-circle text-muted fs-3 me-2"></i>
                                                <div>
                                                    <h6 class="mb-0 text-dark" style="font-size: 14px;">@order.ReceiverName</h6>
                                                    <small class="text-muted">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="fw-bold text-danger">@order.TotalAmount.ToString("N0") đ</td>
                                        <td>
                                            @if (order.Status == "Chờ xử lý")
                                            {
                                                <span class="badge bg-warning text-dark px-2 py-1">@order.Status</span>
                                            }
                                            else if (order.Status == "Đã giao hàng" || order.Status == "Đã xác nhận")
                                            {
                                                <span class="badge bg-success px-2 py-1">@order.Status</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary px-2 py-1">@order.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                @if(!Model.RecentOrders.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-3">Chưa có đơn hàng nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white text-center py-3">
                    <a href="/AdminOrder/Orders" class="btn btn-sm btn-outline-danger shadow-sm">Xem tất cả đơn hàng</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- CHUẨN BỊ THƯ VIỆN CHART.JS -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var ctx = document.getElementById('revenueChart').getContext('2d');
            
            // Xử lý dữ liệu từ Model (C#.NET -> JS)
            var labels = @Json.Serialize(Model.ChartLabels);
            var dataValues = @Json.Serialize(Model.ChartData);

            var revenueChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: dataValues,
                        backgroundColor: 'rgba(220, 53, 69, 0.8)', // Đỏ Vua Giày Hiệu
                        borderColor: 'rgb(220, 53, 69)',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value, index, values) {
                                    if(parseInt(value) >= 1000){
                                        return value.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",") + ' đ';
                                    } else {
                                        return value + ' đ';
                                    }
                                }
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += context.parsed.y.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",") + ' VNĐ';
                                    }
                                    return label;
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}
