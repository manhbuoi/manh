@model cuahanggiay.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng Nhập - Vua Giày Hiệu";
}

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

<!-- LOGIN BANNER -->
<section class="auth-banner">
    <div class="container">
        <div class="banner-content">
            <h1>Chào Mừng Trở Lại</h1>
            <p>Đăng nhập để tiếp tục trải nghiệm mua sắm</p>
        </div>
    </div>
</section>

<!-- BREADCRUMB -->
<section class="breadcrumb-section">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active">Đăng nhập</li>
            </ol>
        </nav>
    </div>
</section>

<!-- LOGIN FORM -->
<section class="auth-section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">
                <div class="auth-card">
                    <div class="auth-header">
                        <div class="auth-icon">
                            <i class="fas fa-sign-in-alt"></i>
                        </div>
                        <h3 class="auth-title">Đăng Nhập</h3>
                        <p class="auth-subtitle">Nhập thông tin tài khoản để tiếp tục</p>
                    </div>

                    <div class="auth-body">
                        <form asp-action="Login" method="post" class="auth-form" novalidate>
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                            <div class="form-group">
                                <label asp-for="Email" class="form-label">
                                    <i class="fas fa-envelope"></i> Email <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="Nhập địa chỉ email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Password" class="form-label">
                                    <i class="fas fa-lock"></i> Mật khẩu <span class="text-danger">*</span>
                                </label>
                                <div class="password-input-container">
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" id="loginPassword" />
                                    <button type="button" class="password-toggle" onclick="togglePassword('loginPassword')">
                                        <i class="fas fa-eye" id="login-icon"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="RememberMe" />
                                    <label class="form-check-label" for="RememberMe">
                                        <i class="fas fa-check-circle"></i> Ghi nhớ đăng nhập
                                    </label>
                                </div>
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-auth">
                                    <i class="fas fa-sign-in-alt"></i> Đăng Nhập
                                </button>
                            </div>
                        </form>

                        <div class="auth-footer">
                            <p class="mb-0">Chưa có tài khoản?
                                <a asp-action="Register" class="auth-link">
                                    <i class="fas fa-user-plus"></i> Đăng ký ngay
                                </a>
                            </p>
                            <p class="mt-2 mb-0">
                                <a href="#" class="text-muted">
                                    <i class="fas fa-key"></i> Quên mật khẩu?
                                </a>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Quick Login Options -->
                <div class="auth-benefits mt-4">
                    <h4 class="benefits-title">
                        <i class="fas fa-bolt"></i> Đăng nhập nhanh
                    </h4>
                    <div class="quick-login-options">
                        <button class="quick-login-btn google-btn">
                            <i class="fab fa-google"></i> Đăng nhập với Google
                        </button>
                        <button class="quick-login-btn facebook-btn">
                            <i class="fab fa-facebook-f"></i> Đăng nhập với Facebook
                        </button>
                    </div>

                    <div class="guest-info mt-3">
                        <p class="text-muted mb-0">
                            <i class="fas fa-info-circle"></i>
                            Khách hàng mới? <a href="#" class="text-primary">Mua hàng không cần tài khoản</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById('login-icon');

            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fas fa-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'fas fa-eye';
            }
        }
    </script>
}