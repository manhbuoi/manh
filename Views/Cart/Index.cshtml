@model cuahanggiay.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container mt-4 mb-5">
    <h2 class="mb-4">Thanh toán đơn hàng</h2>

    <form asp-action="PlaceOrder" method="post">
        <div class="row">
            <div class="col-md-7 mb-4">
                <div class="card shadow-sm border-0 bg-light p-4">
                    <h4 class="mb-3">Thông tin nhận hàng</h4>
                    
                    <div class="row">
                        <div class="col-md-12 form-group mb-3">
                            <label asp-for="FullName" class="fw-bold mb-1">Họ và tên *</label>
                            <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên người nhận" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="PhoneNumber" class="fw-bold mb-1">Số điện thoại *</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="Email" class="fw-bold mb-1">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="Nhập email (không bắt buộc)" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Address" class="fw-bold mb-1">Địa chỉ giao hàng *</label>
                        <input asp-for="Address" class="form-control"
                               placeholder="Số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Note" class="fw-bold mb-1">Ghi chú đơn hàng</label>
                        <textarea asp-for="Note" class="form-control" rows="3"
                                  placeholder="Ghi chú thêm về đơn hàng (thời gian giao hàng...)"></textarea>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card shadow-sm border-0">
                    <div class="card-header text-white" style="background-color: #1a252f;">
                        <h5 class="mb-0 py-1">Đơn hàng của bạn (@Model.CartItems.Count sản phẩm)</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-borderless mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 60px;"></th>
                                        <th>Sản phẩm</th>
                                        <th class="text-center">Số lượng</th>
                                        <th class="text-end">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.CartItems)
                                    {
                                        <tr class="border-bottom">
                                            <td style="width: 60px;">
                                                <img src="@item.ImageUrl" alt="@item.ProductName" class="img-thumbnail"
                                                     style="width: 50px; height: 50px; object-fit: cover;">
                                            </td>
                                            <td>
                                                <span class="fw-bold d-block">@item.ProductName (Size: @item.Size)</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="fw-bold">@item.Quantity</span>
                                            </td>
                                            <td class="text-end text-danger fw-bold align-middle">
                                                @item.Total.ToString("N0") ₫
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-white p-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <span>@Model.CartTotal.ToString("N0") ₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span>Phí vận chuyển:</span>
                            <span>0 ₫</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold" style="font-size: 1.2rem;">Tổng cộng:</span>
                            <span class="fw-bold text-danger" style="font-size: 1.2rem;">@Model.CartTotal.ToString("N0")
                                ₫</span>
                            </div>
                        
                            <button type="submit" class="btn btn-danger w-100 py-3 fw-bold text-uppercase"
                                    style="background-color: #dc3545;">
                                ĐẶT HÀNG
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }