@{
    ViewData["Title"] = "Đặt hàng thành công";
    // Thông tin tài khoản ngân hàng của chủ shop (Admin)
    string bankId = "mbbank"; // Mã ngân hàng (mbbank, vcb, tcb...)
    string accountNo = "0000018026868"; // Số tài khoản của bạn
    string accountName = "BUI CONG MANH"; // Tên chủ tài khoản không dấu
    
    // Tạo link VietQR tự động
    string qrUrl = $"https://img.vietqr.io/image/{bankId}-{accountNo}-compact2.png?amount={ViewBag.Amount}&addInfo=Thanh toan don {ViewBag.OrderId}&accountName={accountName}";
}

<div class="container mt-5 mb-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <i class="text-success" style="font-size: 4rem;">&#10004;</i>
                    <h2 class="text-success mt-3 mb-4">Đặt hàng thành công!</h2>
                    <p class="fs-5">Mã đơn hàng của bạn là: <strong>@ViewBag.OrderId</strong></p>
                    
                    <hr class="my-4" />
                    
                    <h4 class="mb-3">Thanh toán chuyển khoản bằng mã QR</h4>
                    <p class="text-muted">Vui lòng quét mã QR bên dưới bằng ứng dụng ngân hàng. Nội dung và số tiền sẽ
                        được điền tự động.</p>
                    
                        <img src="@qrUrl" alt="Mã QR Thanh Toán" class="img-fluid border rounded p-2 mb-3"
                             style="max-width: 250px;" />
                    
                        <div class="bg-light p-3 rounded text-start mx-auto" style="max-width: 350px;">
                            <p class="mb-1"><strong>Ngân hàng:</strong> MB Bank</p>
                            <p class="mb-1"><strong>Chủ tài khoản:</strong> @accountName</p>
                            <p class="mb-1"><strong>Số tài khoản:</strong> @accountNo</p>
                            <p class="mb-1"><strong>Số tiền:</strong> <span
                                class="text-danger fw-bold">@ViewBag.Amount.ToString("N0") ₫</span></p>
                                <p class="mb-0"><strong>Nội dung:</strong> Thanh toan don @ViewBag.OrderId</p>
                            </div>

                            <div class="mt-4">
                                <a href="/" class="btn btn-outline-secondary">Về trang chủ</a>
                                <a href="/Order/MyOrders" class="btn btn-primary">Theo dõi đơn hàng</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>  